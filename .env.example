# Copy to .env and set your values.
# VITE_ variables are exposed to the browser — do not put private API keys here.
#
# After deploying the Web app from scripts/google-apps-script-rsvp/Code.gs,
# paste the deployment URL (ends with /exec):
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXX/exec
